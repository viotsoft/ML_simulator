# Скопируйте в .env (локально) или задайте в панели хостинга.
# Без Stripe-переменных приложение работает в ДЕМО-режиме оплаты.

# Публичный URL приложения (без слэша в конце) — для redirect'ов Stripe
APP_URL=https://your-app.onrender.com

# Stripe (Dashboard → Developers → API keys)
STRIPE_SECRET_KEY=sk_live_...
# Stripe (Dashboard → Product catalog → ваш продукт → price id подписки $20/мес)
STRIPE_PRICE_ID=price_...
# Stripe (Dashboard → Developers → Webhooks → ваш endpoint → Signing secret)
STRIPE_WEBHOOK_SECRET=whsec_...

# Куда писать данные пользователей (на хостинге — путь к постоянному диску)
DATA_DIR=/data

# Пароль для /admin (список зарегистрированных, HTTP Basic Auth, логин любой).
# Без этой переменной раздел /admin выключен целиком (404) — так безопаснее.
ADMIN_PASSWORD=

# Порт (хостинги обычно передают свой через PORT автоматически)
# PORT=3000
