# Скопируйте в .env (локально) или задайте в панели хостинга.
# Без ключей ниже приложение работает в ДЕМО-режиме оплаты.
# Приоритет, если заданы сразу несколько: WayForPay → Stripe → демо.

# Публичный URL приложения (без слэша в конце) — для redirect'ов/вебхуков
APP_URL=https://your-app.up.railway.app

# --- WayForPay (для мерчанта из Украины, принимает карты со всего мира) ---
# Кабинет: https://secure.wayforpay.com → Мои магазини → ваш магазин
WFP_MERCHANT_ACCOUNT=...
# Там же: Налаштування → Безпека → Секретний ключ
WFP_MERCHANT_SECRET=...
# Там же: отдельный пароль для API управления подпиской (32 символа)
WFP_MERCHANT_PASSWORD=...
# Домен сайта, который вы указали при регистрации магазина в WayForPay
WFP_DOMAIN=your-app.up.railway.app
# Тестовые реквизиты для песочницы (см. DEPLOY.md) — платить не нужно:
#   WFP_MERCHANT_ACCOUNT=test_merch_n1
#   WFP_MERCHANT_SECRET=flk3409refn54t54t*FNJRET

# --- Stripe (если принимаете платежи не из Украины/РФ/СНГ) ---
# Stripe (Dashboard → Developers → API keys)
STRIPE_SECRET_KEY=sk_live_...
# Stripe (Dashboard → Product catalog → ваш продукт → price id подписки $20/мес)
STRIPE_PRICE_ID=price_...
# Stripe (Dashboard → Developers → Webhooks → ваш endpoint → Signing secret)
STRIPE_WEBHOOK_SECRET=whsec_...

# Куда писать данные пользователей (на хостинге — путь к постоянному диску)
DATA_DIR=/data

# Пароль для /admin (список зарегистрированных, HTTP Basic Auth, логин любой).
# Без этой переменной раздел /admin выключен целиком (404) — так безопаснее.
ADMIN_PASSWORD=

# Порт (хостинги обычно передают свой через PORT автоматически)
# PORT=3000
